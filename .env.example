# =============================================================================
# Chat Systems — Environment Template
# =============================================================================
# Copy this file to `.env` and fill in real values. Docker Compose auto-loads
# `.env` from this directory. NEVER commit your real `.env` (it is gitignored).
#
#   cp .env.example .env
#
# The full list of variables with defaults lives in backend/api/src/config.rs.
# Only the secrets below are REQUIRED — the rest have sensible defaults.
# =============================================================================

# ── Required secrets ─────────────────────────────────────────────────────────

# JWT_SECRET — generate with: openssl rand -hex 32
# Must be at least 32 characters; the API refuses to start with a weak/default value.
JWT_SECRET=

# Bootstrap instance admin account (created on first start).
ADMIN_EMAIL=admin@dev.local
ADMIN_PASSWORD=

# PostgreSQL password. Used by the postgres container AND embedded in the
# DATABASE_URL the api/realtime services connect with — keep it consistent.
POSTGRES_PASSWORD=

# ── Instance ─────────────────────────────────────────────────────────────────
INSTANCE_NAME=Chat Systems

# Public-facing base URL. Decides invite/reset email links AND whether auth
# cookies are marked Secure (https → Secure). In production the prod override
# sets this from DOMAIN; locally the default (http://localhost:8080) is fine.
# PUBLIC_URL=http://localhost:8080
# CORS_ORIGINS=http://localhost:8080,http://localhost:3001

# ── Huddle / WebRTC TURN (coturn, `turn` profile) ────────────────────────────
# Huddles use mesh WebRTC. STUN alone works on most home/office networks; TURN
# is the relay fallback required behind symmetric/corporate NAT. All TURN_* vars
# are OPTIONAL — leave them empty and the API serves STUN-only.
#
# To enable relay, run `docker compose --profile turn up -d` and set:
#   TURN_SECRET  — shared secret the API and coturn both use to sign short-lived
#                  credentials (TURN REST API, HMAC-SHA1). openssl rand -hex 32
#   TURN_URLS    — public URLs the browser uses to reach coturn (comma-separated),
#                  e.g. turn:turn.example.com:3478,turns:turn.example.com:5349
#   TURN_REALM   — coturn realm (typically your domain)
TURN_SECRET=
TURN_URLS=
TURN_REALM=chatsystems.local
# STUN_URLS=stun:stun.l.google.com:19302
# TURN_TTL_SECS=43200

# ── Production (docker-compose.prod.yml) ─────────────────────────────────────
# Public domain Caddy serves over auto-HTTPS, and the email for Let's Encrypt.
DOMAIN=chat.example.com
ACME_EMAIL=admin@example.com

# Postgres backup sidecar (prod). Defaults: keep 7 daily dumps.
# BACKUP_RETENTION_DAYS=7
# BACKUP_INTERVAL_SECS=86400

# ── SMTP (defaults mirror config.rs; MailHog for local dev) ───────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@chatsystems.local
SMTP_FROM_NAME=Chat Systems
SMTP_USE_TLS=false

# ── File storage (defaults mirror config.rs) ─────────────────────────────────
# STORAGE_BACKEND: "local" or "s3" (the prod override uses s3 via MinIO).
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/files
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=chatsystems

# MinIO / S3 credentials. The api uses these as its S3 access/secret keys, and
# the MinIO container uses them as its root user/password — keep them in sync.
# Required when running the `s3` profile. NEVER leave the password as a default.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
